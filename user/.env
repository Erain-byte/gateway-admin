# 应用配置
APP_NAME=用户服务
DEBUG=true
HOST=0.0.0.0
PORT=8002

# Gateway 配置
GATEWAY_URL=http://localhost:9000
SERVICE_TTL=300

# 数据库配置
DATABASE_URL=mysql+aiomysql://user:123123@localhost:3306/user

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123123
REDIS_DB=0

# Redis 集群配置（可选）
REDIS_CLUSTER_MODE=false
REDIS_CLUSTER_NODES=
REDIS_POOL_SIZE=20

# Token 配置
TOKEN_EXPIRATION_MINUTES=60

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# HMAC 白名单配置（这些路径不需要 HMAC 签名验证）
HMAC_WHITELIST=/api/auth/*,/api/captcha/*

# 公开路径白名单（逗号分隔，支持通配符 *）
PUBLIC_PATHS=/healthz,/docs,/openapi.json,/redoc,/api/auth/*,/api/captcha/*

# 审计日志敏感路径（逗号分隔，支持通配符 *）
AUDIT_SENSITIVE_PATHS=/api/users/*,/api/profiles/*

# 初始化配置（首次启动设为 true，之后设为 false）
INIT_DEFAULT_DATA=true
